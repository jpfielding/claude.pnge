# PNGE Research Skills — API Keys
# Copy this file to .env and fill in your keys.
# Alternatively, use ~/.config/{service}/credentials files (recommended).
#
# Only 3 of 10 skills require API keys. The rest are free/open.

# EIA Open Data API — get free key at https://www.eia.gov/opendata/
EIA_API_KEY=

# NETL Energy Data eXchange — create free account at https://edx.netl.doe.gov/
NETL_EDX_API_KEY=

# EPA api.data.gov — sign up at https://api.data.gov/signup/
EPA_API_KEY=
